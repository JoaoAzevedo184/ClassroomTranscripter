# ============================================================
# Classroom Transcripter — variáveis de ambiente
# ============================================================
# Copie este arquivo pra .env (que está no .gitignore) e preencha
# APENAS as variáveis das plataformas/providers que você usa.

# ------------------------------------------------------------
# UDEMY (cole cookies do navegador logado — veja docs/sources/udemy.md)
# ------------------------------------------------------------
UDEMY_COOKIE=

# ------------------------------------------------------------
# DIO (Whisper local)
# ------------------------------------------------------------
# Pasta onde você baixa os .mp4 dos bootcamps
DIO_VIDEO_DIR=./dio_videos
# Modelo Whisper: tiny | base | small | medium | large
WHISPER_MODEL=small
WHISPER_LANGUAGE=pt

# ------------------------------------------------------------
# ALURA
# ------------------------------------------------------------
ALURA_EMAIL=
ALURA_PASSWORD=

# ------------------------------------------------------------
# IA Providers (escolha 1 ou mais pra `classroom enrich`)
# ------------------------------------------------------------
# Groq — gratuito, ultra-rápido (recomendado pra começar)
GROQ_API_KEY=

# Gemini — gratuito
GEMINI_API_KEY=

# Claude (Anthropic) — pago
ANTHROPIC_API_KEY=

# Ollama local — padrão http://localhost:11434
OLLAMA_URL=http://localhost:11434
