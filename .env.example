# ─────────────────────────────────────────────────────────────────────────────
# ClassroomTranscripter — Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── Udemy ───────────────────────────────────────────────────────────────────
# String completa de cookies do navegador (obrigatório para download).
# Como obter: DevTools (F12) → Network → qualquer request para udemy.com
#             → Request Headers → copie o valor do header "Cookie"
# IMPORTANTE: Os cookies expiram. Se receber erro 403, gere novos.
UDEMY_COOKIES='cole_aqui_a_string_completa_de_cookies'

# Alternativa: apenas o access_token (menos seguro, pode falhar com Cloudflare)
# UDEMY_ACCESS_TOKEN=seu_access_token_aqui

# ─── Providers de IA (para o comando --enrich) ───────────────────────────────

# Anthropic Claude — https://console.anthropic.com
# Planos pagos. Melhor qualidade de enriquecimento.
# ANTHROPIC_API_KEY=sk-ant-...

# Groq — https://console.groq.com
# Gratuito, sem cartão de crédito, ultra-rápido (LPUs).
# GROQ_API_KEY=gsk_...

# Google Gemini — https://aistudio.google.com
# Gratuito, sem cartão de crédito.
# GEMINI_API_KEY=AIza...

# ─── Configurações opcionais ─────────────────────────────────────────────────

# Ordem de preferência de idiomas para legendas (separados por vírgula).
# Padrão: pt,pt-BR,en,en_US,en_GB,es
# LANG_PRIORITY=pt,en,es

# URL do Ollama (se usar instância remota ou porta diferente)
# Padrão: http://localhost:11434
# OLLAMA_URL=http://localhost:11434
